# PostgreSQL
POSTGRES_DB=kiratakip
POSTGRES_USER=kiratakip
POSTGRES_PASSWORD=kiratakip123

# JWT
JWT_SECRET=guclu_bir_secret_key_buraya_yazin_minimum_32_karakter
JWT_EXPIRES_IN=7d

# CORS ayarları
# Tek origin:
#   CORS_ORIGIN=http://localhost
# Birden fazla origin (virgülle ayır):
#   CORS_ORIGIN=http://localhost,http://192.168.1.50,https://uygulamaniz.com
# Herkese aç (Postman, Android, curl vs.) — '*' tek başına yeterli:
#   CORS_ORIGIN=*
# Tamamen kaldırılırsa da herkese açık olur (geliştirme için)
CORS_ORIGIN=*
